---
import { testimonials } from "../lib/data";

interface Props {
  variant?: "split" | "featured-only";
}
const { variant = "split" } = Astro.props;

const featured = testimonials[0];
const others = testimonials.slice(1);
---

<section class="bg-paper py-24 md:py-36">
  <div class="container-x">
    {
      variant === "featured-only" ? (
        <div class="mx-auto max-w-4xl">
          <figure>
            <blockquote class="font-display text-[28px] leading-[1.25] tracking-tight text-ink md:text-[36px] lg:text-[44px]">
              <span class="text-brand">“</span>{featured.quote}<span class="text-brand">”</span>
            </blockquote>
            <figcaption class="mt-8 flex items-center gap-3 text-[14px] text-muted">
              <span class="h-px w-10 bg-ink/30" />
              <span class="font-medium text-ink">{featured.name}</span>
              {featured.role && <span>· {featured.role}</span>}
            </figcaption>
          </figure>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-x-16">
          <figure class="md:col-span-7">
            <blockquote class="font-display text-[28px] leading-[1.25] tracking-tight text-ink md:text-[36px] lg:text-[42px]">
              <span class="text-brand">“</span>{featured.quote}<span class="text-brand">”</span>
            </blockquote>
            <figcaption class="mt-8 flex items-center gap-3 text-[14px] text-muted">
              <span class="h-px w-10 bg-ink/30" />
              <span class="font-medium text-ink">{featured.name}</span>
              {featured.role && <span>· {featured.role}</span>}
            </figcaption>
          </figure>

          <div class="md:col-span-5 md:border-l md:border-hairline md:pl-12">
            <ul class="divide-y divide-hairline">
              {others.map((t) => (
                <li class="py-6 first:pt-0 last:pb-0">
                  <p class="text-[15px] leading-relaxed text-ink">
                    <span class="text-brand">“</span>{t.quote}<span class="text-brand">”</span>
                  </p>
                  <p class="mt-3 text-[13px] text-muted">
                    <span class="font-medium text-ink">{t.name}</span>
                    {t.role && <span> · {t.role}</span>}
                  </p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )
    }
  </div>
</section>
