---
interface Props {
  eyebrow?: string;
  title: string;
  italicWord?: string;
  intro?: string;
  image?: string;
  imageAlt?: string;
}
const { eyebrow, title, italicWord, intro, image, imageAlt } = Astro.props;

const titleParts = italicWord && title.includes(italicWord)
  ? title.split(italicWord)
  : null;
---

<section class="bg-paper">
  <div class="container-x grid grid-cols-1 items-end gap-12 pb-20 pt-20 md:grid-cols-12 md:gap-x-16 md:pb-28 md:pt-28">
    <div class:list={[image ? "md:col-span-7" : "md:col-span-12 max-w-4xl"]}>
      {eyebrow && <p class="eyebrow mb-5">{eyebrow}</p>}
      <h1 class="font-display text-[40px] leading-[1.1] tracking-tight text-ink md:text-[60px] lg:text-[72px]">
        {
          titleParts ? (
            <>
              {titleParts[0]}
              <span class="italic text-brand">{italicWord}</span>
              {titleParts[1]}
            </>
          ) : (
            title
          )
        }
      </h1>
      {
        intro && (
          <p class="mt-6 max-w-prose text-[17px] leading-relaxed text-muted md:text-lg">
            {intro}
          </p>
        )
      }
    </div>

    {
      image && (
        <div class="md:col-span-5">
          <div class="relative aspect-[4/5] w-full overflow-hidden rounded-[2px] bg-elevated md:ml-auto md:max-w-[420px]">
            <img
              src={image}
              alt={imageAlt ?? ""}
              width="800"
              height="1000"
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/10 to-transparent" />
          </div>
        </div>
      )
    }
  </div>
</section>
