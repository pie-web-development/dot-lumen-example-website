---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import { site } from "../lib/data";

const mapSrc =
  "https://www.openstreetmap.org/export/embed.html?bbox=23.5879%2C46.7700%2C23.5979%2C46.7740&amp;layer=mapnik&amp;marker=46.7720%2C23.5929";
---

<Base
  title="Contact · Cabinet Dental Lumen"
  description="Programări, telefon, adresă și program. Cabinet Dental Lumen, Strada Avram Iancu 14, Cluj-Napoca."
  path="/contact"
>
  <Nav current="contact" />

  <main id="main" class="bg-paper">
    <PageHero
      eyebrow="Contact"
      title="Sună sau scrie. Revenim repede."
      italicWord="Revenim repede"
      intro="Pentru programări, sună sau trimite un email. Răspundem în aceeași zi de lucru, înainte de ora 19."
      image={site.images.contactExterior}
      imageAlt="Intrarea în cabinet, Strada Avram Iancu"
    />

    <section class="container-x pb-24 md:pb-36">
      <div class="grid grid-cols-1 gap-y-12 md:grid-cols-12 md:gap-x-16">
        <div class="md:col-span-5">
          <dl class="space-y-10">
            <div class="border-t border-hairline pt-6">
              <dt class="eyebrow">Telefon</dt>
              <dd class="mt-2 font-display text-[24px] tracking-tight text-ink">
                <a href={site.phoneHref} class="hover:text-brand">{site.phone}</a>
              </dd>
            </div>
            <div class="border-t border-hairline pt-6">
              <dt class="eyebrow">Email</dt>
              <dd class="mt-2 font-display text-[24px] tracking-tight text-ink">
                <a href={site.emailHref} class="hover:text-brand">{site.email}</a>
              </dd>
            </div>
            <div class="border-t border-hairline pt-6">
              <dt class="eyebrow">Adresă</dt>
              <dd class="mt-2 text-[17px] leading-snug text-ink">
                Strada Avram Iancu 14<br />
                Cluj-Napoca, jud. Cluj
              </dd>
            </div>
            <div class="border-t border-hairline pt-6">
              <dt class="eyebrow">Program</dt>
              <dd class="mt-2 text-[17px] leading-snug text-ink">
                {site.hoursLines.map((line) => <span class="block">{line}</span>)}
              </dd>
            </div>
            <div class="border-t border-hairline pt-6">
              <dt class="eyebrow">Pe rețele</dt>
              <dd class="mt-2 flex items-center gap-4 text-[15px]">
                <a href={site.socials.instagram} class="text-ink hover:text-brand" rel="noreferrer noopener" target="_blank">Instagram</a>
                <span class="text-hairline">·</span>
                <a href={site.socials.facebook} class="text-ink hover:text-brand" rel="noreferrer noopener" target="_blank">Facebook</a>
              </dd>
            </div>
          </dl>
        </div>

        <div class="md:col-span-7">
          <div class="aspect-[4/5] w-full overflow-hidden rounded-[2px] bg-elevated md:aspect-[5/6]">
            <iframe
              src={mapSrc}
              class="h-full w-full"
              loading="lazy"
              title="Hartă: Cabinet Dental Lumen, Strada Avram Iancu 14, Cluj-Napoca"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
          <p class="mt-3 text-[13px] text-muted">
            Parcare gratuită la 2 minute pe Strada Iuliu Maniu.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
