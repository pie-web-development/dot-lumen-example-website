---
import "../styles/global.css";
import { url } from "../lib/data";

interface Props {
  title: string;
  description?: string;
  path?: string;
}

const { title, description, path = "/" } = Astro.props;
const siteUrl = "https://dentallumen.ro";
const canonical = `${siteUrl}${path}`;
const metaDescription =
  description ??
  "Cabinet stomatologic în centrul Clujului. Echipă fixă, planuri scrise, programări la oră fixă. Adulți și copii.";
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={url("/favicon.svg")} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ro_RO" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-ink focus:px-4 focus:py-2 focus:text-paper"
    >
      Sari la conținut
    </a>
    <slot />
  </body>
</html>
